# =========================================================================
# paperaglo .env.example — copy to .env on the VPS and fill in real values
# =========================================================================

# ---- PostgreSQL ----------------------------------------------------------
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=paper_trading
PG_USER=paper
PG_PASSWORD=changeme

# ---- Angel One account 1 (SmartConnect) ----------------------------------
ANGEL_API_KEY=your_api_key
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD=your_pin
ANGEL_TOTP_SECRET=your_totp_base32_secret

# ---- Angel One account 2 (optional) ---------------------------------------
# Second SmartAPI account. When all four are set, market-data fetching
# (poller + backfills) automatically moves to this account, leaving account 1
# dedicated to the real-money bot — each account gets its own API rate limit.
# Leave blank to keep everything on account 1.
ANGEL2_API_KEY=
ANGEL2_CLIENT_CODE=
ANGEL2_PASSWORD=
ANGEL2_TOTP_SECRET=

# Role → account routing. Values: 'auto', '1' or '2'.
#   ANGEL_DATA_ACCOUNT     candles/backfill. 'auto' = account 2 when configured, else 1.
#   ANGEL_TRADING_ACCOUNT  the real-money bot. Defaults to 1; never moves implicitly.
ANGEL_DATA_ACCOUNT=auto
ANGEL_TRADING_ACCOUNT=1

# ---- Web dashboard -------------------------------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=8000
DASHBOARD_PASSWORD=changeme_admin
VIEWER_PASSWORD=                      # optional read-only password; leave blank to disable
SESSION_SECRET=change_this_to_a_long_random_string

# ---- Runner timing -------------------------------------------------------
POLLER_INTERVAL_SECONDS=60
TRADER_INTERVAL_SECONDS=60
TRADER_OFFSET_SECONDS=5

# How many calendar days back the real bot may still place an engine signal.
# 1 (default) = today or yesterday — absorbs a signal whose candle arrived after
# market close, so it still gets placed next session. 0 = strict today-only.
# Bump to 3 to also bridge a Monday-after-Friday-signal gap. Keep it small: a
# large value lets a long bot outage fire a burst of old orders when re-enabled.
REAL_TRADER_INTENT_MAX_AGE_DAYS=1

# ---- MCP server ----------------------------------------------------------
# Bearer token Claude uses to authenticate to the MCP endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank (or omit) to disable auth — NOT recommended on a public VPS.
MCP_TOKEN=change_this_to_a_random_hex_string
MCP_HOST=127.0.0.1
MCP_PORT=8001

# ---- Logging -------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
