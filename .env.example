# =========================================================================
# paperaglo .env.example — copy to .env on the VPS and fill in real values
# =========================================================================

# ---- PostgreSQL ----------------------------------------------------------
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=paper_trading
PG_USER=paper
PG_PASSWORD=changeme

# ---- Angel One (SmartConnect) -------------------------------------------
ANGEL_API_KEY=your_api_key
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD=your_pin
ANGEL_TOTP_SECRET=your_totp_base32_secret

# ---- Web dashboard -------------------------------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=8000
DASHBOARD_PASSWORD=changeme_admin
VIEWER_PASSWORD=                      # optional read-only password; leave blank to disable
SESSION_SECRET=change_this_to_a_long_random_string

# ---- Runner timing -------------------------------------------------------
POLLER_INTERVAL_SECONDS=60
TRADER_INTERVAL_SECONDS=60
TRADER_OFFSET_SECONDS=5

# ---- MCP server ----------------------------------------------------------
# Bearer token Claude uses to authenticate to the MCP endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank (or omit) to disable auth — NOT recommended on a public VPS.
MCP_TOKEN=change_this_to_a_random_hex_string
MCP_HOST=127.0.0.1
MCP_PORT=8001

# ---- Logging -------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
