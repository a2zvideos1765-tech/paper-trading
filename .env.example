# ─── Database ────────────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=paper_trading
PG_USER=paper
PG_PASSWORD=change-me

# ─── Angel One SmartAPI ──────────────────────────────────────
# Generate at https://smartapi.angelbroking.com/
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PASSWORD=
# This is the TOTP *secret* (the base32 setup key shown when you enable 2FA),
# NOT the 6-digit OTP. The app will compute the OTP from it on each login.
ANGEL_TOTP_SECRET=

# ─── Web dashboard ───────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000
# Single shared password to view the dashboard.
DASHBOARD_PASSWORD=change-me
# Random 32+ char string. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me

# ─── Runners ────────────────────────────────────────────────
# Poll every N seconds during market hours.
POLLER_INTERVAL_SECONDS=60
# Trader sleeps this many seconds after each tick.
TRADER_INTERVAL_SECONDS=60
# Offset trader start within the minute so the poller writes first.
TRADER_OFFSET_SECONDS=5

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
