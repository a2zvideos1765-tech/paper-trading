# Replace paper.studiohappens.tech with your actual domain. Caddy fetches Let's Encrypt
# certs automatically the first time it boots.
#
# Install on the VPS:
#   sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
#     | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
#     | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#   sudo apt update && sudo apt install caddy
#
#   sudo cp Caddyfile.example /etc/caddy/Caddyfile     # then edit the domain
#   sudo systemctl reload caddy

paper.studiohappens.tech {
    encode gzip zstd

    # FastAPI dashboard lives on localhost:8000 (WEB_PORT in .env).
    reverse_proxy 127.0.0.1:8000 {
        header_up X-Real-IP {remote_host}
    }

    # Reasonable defaults for a small dashboard.
    log {
        output file /var/log/caddy/paperaglo.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

# MCP server — Claude connects here to read/debug the platform.
# The MCP_TOKEN bearer check is enforced by the MCP server itself,
# but we also guard it at the Caddy layer for defence-in-depth:
# any request without the correct Authorization header gets a 401
# before it ever reaches the Python process.
#
# Replace MCP_TOKEN_VALUE with the actual token from your .env,
# or just rely on the Python-level auth and remove the @no_token block.
mcp.studiohappens.tech {
    encode gzip zstd

    @no_token {
        not header Authorization "Bearer {env.MCP_TOKEN}"
    }
    respond @no_token "Unauthorized" 401

    # MCP server (streamable-http transport) on MCP_PORT (default 8001).
    reverse_proxy 127.0.0.1:8001 {
        header_up X-Real-IP {remote_host}
        # SSE connections must stay alive for the duration of the tool call.
        flush_interval -1
    }

    log {
        output file /var/log/caddy/paperaglo-mcp.log {
            roll_size 10mb
            roll_keep 3
        }
    }
}
